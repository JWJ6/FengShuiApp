# Server
PORT=3000
NODE_ENV=production

# JWT — MUST change in production (use: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_TO_RANDOM_SECRET

# PostgreSQL — use DATABASE_URL for Railway/Render
DATABASE_URL=postgresql://user:password@host:5432/fengshui
# Or use individual vars:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=fengshui
# DB_USER=postgres
# DB_PASSWORD=password
DB_POOL_MAX=20

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-api03-xxx

# Email (SMTP)
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your_email@qq.com
SMTP_PASS=your_smtp_password

# Stripe
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Web URL (for Stripe redirect)
WEB_BASE_URL=https://yourdomain.com

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
